{
  "Jwt": {
    "Issuer": "CareConnectEgypt",
    "Audience": "CareConnectEgyptClient",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7,
    "ClockSkewSeconds": 30
  },
  "SuperAdmin": {
    "FullName": "CareConnect Administrator"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/careconnect-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
